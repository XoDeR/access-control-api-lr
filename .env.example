APP_NAME="Access Control API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database — works with Docker Compose OR a locally installed PostgreSQL.
# Start Docker services:  docker compose up -d
# Use local Postgres:    point DB_* at your existing instance (same keys).
# ---------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=access_control
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ---------------------------------------------------------------------------
# Redis — works with Docker Compose OR a locally installed Redis.
# Start Docker services:  docker compose up -d
# Use local Redis:        point REDIS_* at your existing instance (same keys).
# ---------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=array

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# JWT access + refresh token settings
JWT_SECRET=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_ISSUER="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
